---
import Base from '../layouts/Base.astro';
---

<Base title="Privacy Policy" description="Privacy policy for Shift at Midnight Compass — no ads, no analytics, no data collection.">
  <div class="panel hero" style="padding: 28px;">
    <span class="eyebrow"><span class="dot accent"></span> Privacy</span>
    <h1>Privacy Policy</h1>
  </div>

  <section class="panel section">
    <h2>Data Collection</h2>
    <p style="margin-top: 8px;">Shift at Midnight Compass does <strong>not</strong> collect, store, or share any personal data. This site has:</p>
    <ul style="margin-top: 8px; padding-left: 20px; display: grid; gap: 6px; color: var(--muted); font-size: 14px; line-height: 1.6;">
      <li>No analytics scripts</li>
      <li>No advertising scripts</li>
      <li>No cookies or tracking</li>
      <li>No user accounts or forms that store data</li>
      <li>No third-party data sharing</li>
    </ul>
  </section>

  <section class="panel section">
    <h2>External Links</h2>
    <p style="margin-top: 8px;">This site links to Steam Store, Xbox Store, YouTube, and press articles. Those external sites are governed by their own privacy policies. This site is not responsible for the data practices of any linked external site.</p>
  </section>

  <section class="panel section">
    <h2>Hosting &amp; Server Logs</h2>
    <p style="margin-top: 8px;">This site is hosted on Vercel. Like most hosting providers, Vercel may collect basic server logs such as requested URLs, IP addresses, and browser user agents. This is standard hosting infrastructure behavior and is outside this site's control.</p>
  </section>

  <section class="panel section">
    <h2>Children's Privacy</h2>
    <p style="margin-top: 8px;">This site does not knowingly collect data from children under 13. The site has no content designed to attract children.</p>
  </section>

  <section class="panel section">
    <h2>Changes to This Policy</h2>
    <p style="margin-top: 8px;">If this privacy policy changes, the updated version will be posted on this page with a revised date. This page was last reviewed at site creation.</p>
  </section>
</Base>
